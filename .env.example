# ─────────────────────────────────────────────
# NU Connect — Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# Telegram Bot Token
# Get from: @BotFather → /newbot → copy token
BOT_TOKEN=

# Supabase
# Get from: supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=   # secret key — backend only, never expose to frontend

# Google Gemini (free tier: 1,500 req/day)
# Get from: aistudio.google.com → Get API key
GEMINI_API_KEY=

# Resend (free tier: 3,000 emails/month) — for sending OTP emails
# Get from: resend.com → API Keys → Create
RESEND_API_KEY=

# ─── Frontend (Vite) ───
# These are PUBLIC — safe to expose in browser
# Set these in Vercel dashboard under Environment Variables

# Your Supabase project's Edge Functions base URL
VITE_SUPABASE_FUNCTIONS_URL=https://xxxxxxxxxxxx.supabase.co/functions/v1
